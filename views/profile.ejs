<!DOCTYPE html>
<html lang="sv">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Min profil</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link rel="stylesheet" href="/css/main.css" />
</head>


<body class="profile-page">

    <div class="header-container"><%- include('partials/header') %></div>
    <nav class="nav-bar"></nav>

    <main class="profile-page-container">

        <div class="container py-5">

            <div class="row justify-content-center">

                <div class="col-12 col-lg-9" id="profileSection">

                    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                        <div class="card-body p-4 p-md-5 bg-dark text-light">

                            <div class="row g-4 align-items-start">

                                <!-- VÄNSTER DEL / PROFIL -->

                                <div class="col-12 col-lg-4 text-center text-lg-start">

                                    <div class="mx-auto mx-lg-0 d-flex align-items-center justify-content-center rounded-circle bg-light"
                                        style="width:140px;height:140px;">

                                        <i class="fa-regular fa-user fs-1 text-dark"></i>

                                    </div>

                                    <h1 id="profileName" class="h2 fw-bold mt-4 mb-2 text-center text-lg-start">
                                        Min profil
                                    </h1>

                                    <p class="text-secondary small mb-4 text-center text-lg-start">
                                        Kino medlem
                                    </p>

                                    <button id="logoutBtn"
                                        class="btn btn-link text-decoration-underline text-light p-0">
                                        Logga ut
                                    </button>

                                </div>


                                <!-- HÖGER DEL / MENY -->

                                <div class="col-12 col-lg-8">

                                    <div class="list-group">

                                        <a href="#"
                                            class="list-group-item list-group-item-action d-flex justify-content-between align-items-center bg-black text-white border-secondary rounded-3 mb-2">

                                            <span>
                                                <i class="fa-regular fa-id-card me-2"></i>
                                                Mitt medlemskap
                                            </span>

                                            <i class="fa-solid fa-chevron-right"></i>

                                        </a>


                                        <a href="#"
                                            class="list-group-item list-group-item-action d-flex justify-content-between align-items-center bg-black text-white border-secondary rounded-3 mb-2">

                                            <span>
                                                <i class="fa-solid fa-ticket me-2"></i>
                                                Biljetter och bokningar
                                            </span>

                                            <i class="fa-solid fa-chevron-right"></i>

                                        </a>


                                        <a href="#"
                                            class="list-group-item list-group-item-action d-flex justify-content-between align-items-center bg-black text-white border-secondary rounded-3 mb-2">

                                            <span>
                                                <i class="fa-regular fa-star me-2"></i>
                                                Personliga erbjudanden
                                            </span>

                                            <i class="fa-solid fa-chevron-right"></i>

                                        </a>


                                        <a href="#"
                                            class="list-group-item list-group-item-action d-flex justify-content-between align-items-center bg-black text-white border-secondary rounded-3 mb-2">

                                            <span>
                                                <i class="fa-regular fa-comment me-2"></i>
                                                Recensioner
                                            </span>

                                            <i class="fa-solid fa-chevron-right"></i>

                                        </a>


                                        <a href="#" id="detailsLink"
                                            class="list-group-item list-group-item-action d-flex justify-content-between align-items-center bg-black text-white border-secondary rounded-3">

                                            <span>
                                                <i class="fa-solid fa-gear me-2"></i>
                                                Mina uppgifter
                                            </span>

                                            <i class="fa-solid fa-chevron-right"></i>

                                        </a>

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </main>

    <div class="footer__container"><%- include('partials/footer') %></div>

    <script type="module" src="/js/main.js"></script>
    <script type="module" src="/js/profilePage.js"></script>

</body>

</html>